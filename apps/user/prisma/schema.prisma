generator client {
  provider     = "prisma-client"
  output       = "../src/infra/persistence/prisma/generated"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String        @id @default(uuid())
  email          String        @unique
  name           String
  status         UserStatus    @default(ACTIVE)
  role           UserRole      @default(CUSTOMER)
  passwordHash   String?
  dormantAt      DateTime?
  suspendedAt    DateTime?
  withdrawnAt    DateTime?
  lastLoginAt    DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  profile        UserProfile?
  sessions       UserSession[]
  authIdentities UserAuthIdentity[]
  agreements     UserAgreement[]
  statusHistories UserStatusHistory[]
  memberships    UserMembership[]
  grades         UserGrade[]
  withdrawn      WithdrawnUser?

  @@index([status])
  @@index([createdAt])
}

model UserProfile {
  id                String   @id @default(uuid())
  userId             String   @unique
  nickname           String?
  bio                String?
  phone              String?  @unique
  birthDate          DateTime?
  gender             Gender?
  profileImageUrl    String?
  timezone           String?  @default("Asia/Seoul")
  addressLine1       String?
  addressLine2       String?
  postalCode         String?
  marketingEmailOptIn Boolean @default(false)
  marketingSmsOptIn   Boolean @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserSession {
  id           String      @id @default(uuid())
  userId       String
  refreshHash  String
  deviceId     String?
  ip           String?
  userAgent    String?
  lastSeenAt   DateTime?
  expiresAt    DateTime
  revokedAt    DateTime?
  createdAt    DateTime    @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
  @@index([deviceId])
}

model UserAuthIdentity {
  id             String             @id @default(uuid())
  userId          String
  provider        AuthProvider
  providerUserId  String
  email           String?
  linkedAt        DateTime           @default(now())
  lastLoginAt     DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@index([userId])
}

model UserAgreement {
  id            String         @id @default(uuid())
  userId         String
  type           AgreementType
  version        String
  isAgreed       Boolean
  agreedAt       DateTime?
  revokedAt      DateTime?
  createdAt      DateTime       @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
  @@index([type, version])
}

model UserStatusHistory {
  id          String      @id @default(uuid())
  userId       String
  fromStatus   UserStatus?
  toStatus     UserStatus
  reason       String?
  changedBy    String?
  changedAt    DateTime    @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, changedAt])
}

model MembershipPlan {
  id                 String          @id @default(uuid())
  code               String          @unique
  name               String
  description        String?
  status             PlanStatus      @default(ACTIVE)
  billingPeriod      BillingPeriod
  price              Decimal         @db.Decimal(12, 2)
  currency           String          @default("KRW")
  benefits           Json?
  sortOrder          Int             @default(0)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  memberships        UserMembership[]

  @@index([status, sortOrder])
}

model UserMembership {
  id                 String            @id @default(uuid())
  userId              String
  planId              String
  status              MembershipStatus  @default(ACTIVE)
  startedAt           DateTime
  endedAt             DateTime?
  canceledAt          DateTime?
  autoRenew           Boolean           @default(true)
  nextBillingAt       DateTime?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan MembershipPlan @relation(fields: [planId], references: [id])

  @@index([userId, status])
  @@index([planId])
}

model GradePolicy {
  id                   String    @id @default(uuid())
  grade                UserGradeType @unique
  minOrderCount        Int?
  minPaidAmount        Decimal?  @db.Decimal(14, 2)
  priority             Int       @default(0)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
}

model UserGrade {
  id                String        @id @default(uuid())
  userId             String
  grade              UserGradeType
  reason             String?
  effectiveFrom      DateTime      @default(now())
  effectiveTo        DateTime?
  createdAt          DateTime      @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, effectiveFrom])
  @@index([grade])
}

model WithdrawnUser {
  id                   String    @id @default(uuid())
  userId                String    @unique
  reason                String?
  detail                String?
  withdrawnAt           DateTime  @default(now())
  retentionUntil        DateTime?
  anonymizedAt          DateTime?
  rejoinBlockedUntil    DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([withdrawnAt])
}

enum UserStatus {
  ACTIVE
  DORMANT
  SUSPENDED
  WITHDRAWN
}

enum UserRole {
  CUSTOMER
  ADMIN
  OPERATOR
}

enum Gender {
  MALE
  FEMALE
  OTHER
  UNKNOWN
}

enum AuthProvider {
  LOCAL
  GOOGLE
  APPLE
  KAKAO
  NAVER
}

enum AgreementType {
  TERMS_OF_SERVICE
  PRIVACY_POLICY
  MARKETING_EMAIL
  MARKETING_SMS
  MARKETING_PUSH
}

enum PlanStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum BillingPeriod {
  MONTHLY
  YEARLY
}

enum MembershipStatus {
  ACTIVE
  PAUSED
  CANCELED
  EXPIRED
}

enum UserGradeType {
  BRONZE
  SILVER
  GOLD
  PLATINUM
  VIP
}
