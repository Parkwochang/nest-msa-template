{
  "name": "@repo/config",
  "version": "0.0.0",
  "private": true,
  "exports": {
    "./auth": {
      "types": "./dist/auth/index.d.ts",
      "default": "./dist/auth/index.js"
    },
    "./grpc": {
      "types": "./dist/grpc/index.d.ts",
      "default": "./dist/grpc/index.js"
    },
    "./env": {
      "types": "./dist/env/index.d.ts",
      "default": "./dist/env/index.js"
    },
    "./health": {
      "types": "./dist/health/index.d.ts",
      "default": "./dist/health/index.js"
    }
  },
  "typesVersions": {
    "*": {
      "auth": [
        "./dist/auth/index.d.ts"
      ],
      "grpc": [
        "./dist/grpc/index.d.ts"
      ],
      "env": [
        "./dist/env/index.d.ts"
      ],
      "health": [
        "./dist/health/index.d.ts"
      ]
    }
  },
  "scripts": {
    "build": "tsc --build",
    "dev": "tsc --build --watch",
    "clean": "rm -rf dist",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "@repo/core": "workspace:*",
    "opossum": "catalog:circuit-breaker",
    "@nestjs/terminus": "catalog:nestjs"
  },
  "devDependencies": {
    "@nestjs/jwt": "catalog:auth",
    "@nestjs/common": "catalog:nestjs",
    "@nestjs/config": "catalog:nestjs",
    "@nestjs/core": "catalog:nestjs",
    "@nestjs/microservices": "catalog:nestjs",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^22.10.7",
    "typescript": "catalog:",
    "rxjs": "catalog:",
    "zod": "catalog:validation",
    "@types/opossum": "catalog:circuit-breaker"
  },
  "peerDependencies": {
    "@nestjs/common": "catalog:nestjs",
    "@nestjs/core": "catalog:nestjs",
    "@nestjs/config": "catalog:nestjs"
  }
}
